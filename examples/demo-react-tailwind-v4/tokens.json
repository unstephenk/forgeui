{
  "$metadata": {
    "name": "ForgeUI Demo Tokens",
    "version": "1.0.0"
  },
  "$sets": {
    "core": "enabled",
    "components": "enabled"
  },
  "$themes": [
    {
      "id": "t_light",
      "name": "Light",
      "selectedTokenSets": {
        "core": "enabled",
        "components": "enabled"
      }
    },
    {
      "id": "t_dark",
      "name": "Dark",
      "selectedTokenSets": {
        "core": "enabled",
        "components": "enabled"
      }
    }
  ],
  "core": {
    "color": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": {
            "Light": "#FFFFFF",
            "Dark": "#0B0F19"
          }
        },
        "subtle": {
          "$type": "color",
          "$value": {
            "Light": "#F8FAFC",
            "Dark": "#111827"
          }
        }
      },
      "fg": {
        "default": {
          "$type": "color",
          "$value": {
            "Light": "#0B0F19",
            "Dark": "#F8FAFC"
          }
        },
        "muted": {
          "$type": "color",
          "$value": {
            "Light": "#475569",
            "Dark": "#94A3B8"
          }
        }
      },
      "brand": {
        "500": {
          "$type": "color",
          "$value": {
            "Light": "#6366F1",
            "Dark": "#818CF8"
          }
        },
        "700": {
          "$type": "color",
          "$value": {
            "Light": "#4338CA",
            "Dark": "#A5B4FC"
          }
        }
      },
      "danger": {
        "500": {
          "$type": "color",
          "$value": {
            "Light": "rgb(239, 68, 68)",
            "Dark": "hsl(0 90% 70%)"
          }
        }
      }
    },
    "space": {
      "0": { "$type": "dimension", "$value": 0 },
      "1": { "$type": "dimension", "$value": 4 },
      "2": { "$type": "dimension", "$value": 8 },
      "4": { "$type": "dimension", "$value": 16 },
      "6": { "$type": "dimension", "$value": 24 },
      "8": { "$type": "dimension", "$value": 32 }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": 6 },
      "md": { "$type": "dimension", "$value": 10 },
      "lg": { "$type": "dimension", "$value": 14 }
    },
    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": [
          { "color": "rgba(0,0,0,0.10)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
        ]
      }
    }
  },
  "components": {
    "button": {
      "bg": {
        "default": { "$type": "color", "$value": "{core.color.brand.500}" },
        "hover": { "$type": "color", "$value": "{core.color.brand.700}" }
      },
      "fg": {
        "default": { "$type": "color", "$value": "{core.color.bg.default}" }
      },
      "radius": { "$type": "dimension", "$value": "{core.radius.md}" }
    },
    "card": {
      "bg": {
        "default": { "$type": "color", "$value": "{core.color.bg.subtle}" }
      },
      "fg": {
        "default": { "$type": "color", "$value": "{core.color.fg.default}" }
      },
      "radius": { "$type": "dimension", "$value": "{core.radius.lg}" },
      "shadow": { "$type": "shadow", "$value": "{core.shadow.sm}" }
    }
  }
}

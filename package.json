{
  "name": "@forgeui/cli",
  "version": "0.0.1",
  "description": "ForgeUI CLI — Tokens Studio → Tailwind v4 + CSS variables generator",
  "type": "module",
  "bin": {
    "forgeui": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "fixtures",
    "forgeui.config.schema.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npx tsup src/index.ts src/api.ts --format esm --platform node --target node20 --dts",
    "prepack": "npm run build",
    "test": "npx vitest run",
    "release": "node scripts/release.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "keywords": [
    "design-tokens",
    "tokens-studio",
    "tailwind",
    "tailwindcss",
    "css-variables",
    "figma"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unstephenk/forgeui.git"
  },
  "bugs": {
    "url": "https://github.com/unstephenk/forgeui/issues"
  },
  "homepage": "https://github.com/unstephenk/forgeui#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "cac": "^6.7.14",
    "chokidar": "^3.6.0",
    "jiti": "^2.4.2",
    "picomatch": "^4.0.2",
    "prettier": "^3.5.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22.13.10",
    "prettier": "^3.5.2",
    "tsup": "^8.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}

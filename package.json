{
  "name": "@forgeui/cli",
  "version": "0.0.1",
  "description": "ForgeUI CLI — Tokens Studio → Tailwind v4 + CSS variables generator",
  "type": "module",
  "bin": {
    "forgeui": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "fixtures"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node20 --dts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "keywords": [
    "design-tokens",
    "tokens-studio",
    "tailwind",
    "tailwindcss",
    "css-variables",
    "figma"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unstephenk/forgeui.git"
  },
  "bugs": {
    "url": "https://github.com/unstephenk/forgeui/issues"
  },
  "homepage": "https://github.com/unstephenk/forgeui#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.2",
    "tsup": "^8.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
